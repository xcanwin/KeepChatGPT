{
  "name": "keepchatgpt",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n server,test -c cyan,yellow \"node tools/dev-server.js\" \"jest --watchAll --verbose\"",
    "test": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4"
  },
  "overrides": {
    "js-yaml": "^5.0.0"
  }
}
